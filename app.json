{
  "expo": {
    "name": "ScanPal",
    "slug": "scanpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "scanpal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.scanpal.app" },
    "android": { "package": "com.scanpal.app" },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        { "cameraPermission": "Allow ScanPal to access your camera to scan documents." }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
