{
  "expo": {
    "name": "ScanPal",
    "slug": "scanpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "scanpal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scanpal.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "ScanPal uses the camera to scan documents and text.",
        "NSPhotoLibraryAddUsageDescription": "ScanPal saves exported scans to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.scanpal.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "ScanPal uses the camera to scan documents and text."
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "REPLACE_WITH_EAS_PROJECT_ID" }
    }
  }
}
